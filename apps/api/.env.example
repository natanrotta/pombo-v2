# ================= CORE =================
NODE_ENV=local
API_PORT=3343
# Allowed CORS origin(s) — the web app URL. NEVER "*" in production.
ALLOWED_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ================ DATABASE ===============
# REQUIRED. Postgres connection string.
DATABASE_URL="postgresql://postgres:123123@localhost:5442/postgres?schema=public"

# ================= REDIS =================
REDIS_HOST=localhost
REDIS_PORT=6389
REDIS_PASSWORD=
REDIS_DB=0

# ================== JWT ==================
# REQUIRED, >= 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-secret-of-at-least-32-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
# Cookie domain shared between app/api (e.g. .example.com). Blank in local dev.
COOKIE_DOMAIN=
# Optional — OAuth 2.0 Client ID for "Sign in with Google".
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ========= PASSWORD RESET / EMAIL VERIFY =========
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_PIN_TTL_MINUTES=15

# ============ MAIL (RESEND) — optional ===========
# Transactional e-mail (password reset, verification PIN). Blank = disabled.
RESEND_API_KEY=
MAIL_FROM=Pombo <no-reply@example.com>
MAIL_DEV_REDIRECT_TO=

# ========= OBJECT STORAGE (S3) — optional ========
# For avatar/file uploads. Blank = disabled.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ============= OBSERVABILITY — optional ==========
# Error reporting (Bugsnag). Blank = disabled.
BUGSNAG_API_KEY=
# App version / commit shown at GET /api/health. Usually stamped by CI.
APP_VERSION=
# node_exporter host-metrics scrape URLs (must be valid URLs when set).
# METRICS_APP_URL=
# METRICS_DATA_URL=
# GitHub Actions read-only token + repo, for CI/CD run listing.
GITHUB_ACTIONS_TOKEN=
GITHUB_REPO=owner/repo

# ============= RATE LIMITING =============
RATE_LIMIT_GLOBAL_WINDOW_MS=300000
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_USER_WINDOW_MS=60000
RATE_LIMIT_USER_MAX=200
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PUBLIC_WINDOW_MS=900000
RATE_LIMIT_PUBLIC_MAX=30

# ========= WHATSAPP GATEWAY (pombo) =========
# Master flag. false (default) = the API boots with NO Baileys import, no
# advisory lock, no socket, no rehydration, no outbox prune. All HTTP endpoints
# still respond; POST /devices/:id/connect returns WA_GATEWAY_DISABLED.
# Set true only on the single replica that owns the live WhatsApp sockets.
WHATSAPP_ENABLED=false
# Socket flap debounce before emitting a device.disconnected webhook.
# DISCONNECT_DEBOUNCE_MS=30000
# Reconnect backoff (exponential, capped).
# RECONNECT_BASE_DELAY_MS=3000
# RECONNECT_MAX_DELAY_MS=300000
# Outbox is protocol, not history: rows past this TTL are pruned.
# OUTBOX_TTL_HOURS=24
# OUTBOX_PRUNE_INTERVAL_MS=3600000
# Per-device outbound send throttle (anti-ban): at most SEND_RATE_MAX sends per
# SEND_RATE_WINDOW_MS, shared by the live send and the reconnect drain; the
# excess is queued and drained as the budget frees. Tune to the number's reputation.
# SEND_RATE_MAX=20
# SEND_RATE_WINDOW_MS=60000
# Webhook delivery (HMAC-signed, bounded retries).
# WEBHOOK_TIMEOUT_MS=5000
# WEBHOOK_MAX_ATTEMPTS=4
# WEBHOOK_RETRY_BASE_DELAY_MS=1000
# Advisory-lock heartbeat (single-replica guard).
# ADVISORY_LOCK_HEARTBEAT_MS=30000
