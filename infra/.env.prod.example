# infra/.env.prod.example — production .env template for the API (VPS-APP).
#
# Copy to infra/.env.prod on the VPS-APP, fill the <PLACEHOLDERS> and:
#   chmod 600 infra/.env.prod
#
# Source of truth: apps/api/src/core/config (Zod validates on boot and
# process.exit(1)s if a required var is missing). Only DATABASE_URL and
# JWT_SECRET are required with no default; everything else has a default.

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3333
PROJECT_NAME=boilerplate
LOG_LEVEL=info
# Allowed CORS origin(s) — the web app domain. NEVER "*" in production.
ALLOWED_ORIGIN=https://app.example.com
# Frontend base used in e-mail links (password reset, etc.).
FRONTEND_URL=https://app.example.com
# Auth cookie domain (shared between app/api).
COOKIE_DOMAIN=.example.com
DEV_QUICK_LOGIN_ENABLED=false

# ── Database (over the WireGuard tunnel) ─────────────────────────────────────
# REQUIRED. Points at the VPS-DATA over the tunnel IP (10.8.0.2).
DATABASE_URL=postgresql://boilerplate:<DB_PASSWORD>@10.8.0.2:5432/boilerplate

# ── Redis (over the tunnel) ──────────────────────────────────────────────────
REDIS_HOST=10.8.0.2
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_DB=0

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# REQUIRED, >= 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=<JWT_SECRET_AT_LEAST_32_CHARS>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
# Optional: Google OAuth client id for "Sign in with Google".
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>

# ── Object storage (S3) — optional, for avatars/uploads ──────────────────────
# Leave blank to disable the storage provider.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
AWS_S3_BUCKET=<AWS_S3_BUCKET>

# ── E-mail (Resend) — optional, for password-reset / verification e-mails ────
RESEND_API_KEY=<RESEND_API_KEY>
MAIL_FROM=Boilerplate <no-reply@example.com>
# MAIL_DEV_REDIRECT_TO=  # dev only — leave blank in prod

# ── Observability (optional) ─────────────────────────────────────────────────
# APP_VERSION is stamped onto the image by CI (--build-arg APP_VERSION=<git sha>)
# and surfaced at GET /api/health. Leave commented so the image value wins.
# APP_VERSION=
# node_exporter of each VPS, bound to the WireGuard tunnel IP (never expose
# :9100 publicly). Optional — blank means "host metrics not configured".
METRICS_APP_URL=http://10.8.0.1:9100/metrics
METRICS_DATA_URL=http://10.8.0.2:9100/metrics

# ── Rate limiting (env defaults — override if needed) ────────────────────────
# RATE_LIMIT_GLOBAL_MAX=1000
# RATE_LIMIT_AUTH_MAX=10
