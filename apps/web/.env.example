# Copy this file to `.env` (gitignored) and fill in the values you need.
# All vars are optional for local dev — the app falls back gracefully when
# they are blank.

# ============= API =====================
# Base URL for the API (axios baseURL). The backend serves under "/api", so a
# full URL includes it (e.g. https://api.example.com/api). Leave empty to use
# the Vite dev proxy defined in vite.config.ts.
VITE_API_URL=

# ============= GOOGLE OAUTH =============
# OAuth 2.0 Client ID from https://console.cloud.google.com/apis/credentials.
# Public value — it ships in the client bundle. Must match the GOOGLE_CLIENT_ID
# the API validates (the ID token audience has to line up). Leave empty to
# disable the "Sign in with Google" button.
VITE_GOOGLE_CLIENT_ID=

# ============= BUGSNAG ==================
# Browser notifier API key from https://app.bugsnag.com
#   → Project Settings → Notifier API Key.
# Public by design (ships in the bundle). Leave empty to disable error and
# performance reporting.
VITE_BUGSNAG_API_KEY=

# ============= VERSION =================
# Optional override for the build-time version stamp shown in the sidebar.
# When unset, the build falls back to the deploy commit SHA or "dev" locally.
# Set it to pin a release tag (e.g. v1.2) for QA.
VITE_APP_VERSION=
