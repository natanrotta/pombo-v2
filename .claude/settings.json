{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-backend.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-frontend.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-e2e.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(yarn type-check)",
      "Bash(yarn lint)",
      "Bash(yarn lint:*)",
      "Bash(yarn test)",
      "Bash(yarn test:*)",
      "Bash(yarn format)",
      "Bash(yarn format:check)",
      "Bash(yarn workspace @pombo/api test)",
      "Bash(yarn workspace @pombo/api test:*)",
      "Bash(yarn workspace @pombo/web test:e2e)"
    ]
  }
}
