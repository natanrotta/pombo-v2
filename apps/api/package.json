{
  "name": "@boilerplate/api",
  "version": "2.0.0",
  "description": "Boilerplate API - Clean Architecture REST API",
  "main": "dist/main.js",
  "author": "natanrotta",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' tsx watch src/main.ts",
    "debug": "NODE_OPTIONS='--max-old-space-size=2048' tsx --inspect src/main.ts",
    "debug:watch": "NODE_OPTIONS='--max-old-space-size=2048' tsx watch --inspect src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "postinstall": "if [ -f prisma/schema.prisma ]; then prisma generate; fi",
    "prisma:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:studio": "prisma studio",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "seed": "tsx prisma/seed.ts",
    "db:reset-seed": "yarn prisma:reset && yarn seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@bugsnag/js": "^8.10.0",
    "@bugsnag/plugin-express": "^8.9.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@boilerplate/shared-types": "*",
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@signpdf/placeholder-plain": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@signpdf/utils": "^3.3.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.2",
    "chardet": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.3.0",
    "i18next": "^25.8.20",
    "i18next-fs-backend": "^2.6.6",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.13.8",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "node-cron": "^3.0.3",
    "openai": "^6.46.0",
    "papaparse": "^5.5.4",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "1.1.1",
    "pdf-to-img": "^5.0.0",
    "pino": "^9.11.0",
    "pino-http": "^10.5.0",
    "rate-limit-redis": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.17.2",
    "stripe": "^22.3.1",
    "tsyringe": "^4.8.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
