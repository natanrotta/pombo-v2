{
  "name": "@pombo/web",
  "version": "1.0.0",
  "private": true,
  "description": "Pombo - Web Client",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "tsx scripts/e2e-run.ts",
    "test:e2e:keep": "tsx scripts/e2e-run.ts --keep",
    "test:e2e:ui": "tsx scripts/e2e-run.ts --keep --ui",
    "test:e2e:headed": "tsx scripts/e2e-run.ts --keep --headed",
    "test:e2e:down": "docker compose -f ../../docker-compose.e2e.yml down -v",
    "test:e2e:report": "npx playwright show-report .playwright/report"
  },
  "dependencies": {
    "@bugsnag/browser-performance": "^3.4.1",
    "@bugsnag/js": "^8.10.0",
    "@chakra-ui/anatomy": "^2.2.2",
    "@chakra-ui/react": "2.8.2",
    "@chakra-ui/theme-tools": "^2.1.2",
    "@pombo/shared-types": "*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.12",
    "framer-motion": "10.16.4",
    "i18next": "^25.8.20",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^1.24.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^6.20.0",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.37",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^1.6.0",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^24.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
