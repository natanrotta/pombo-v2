# /etc/boilerplate/backup.env — config dos scripts de backup (VPS-DATA).
# Copie para /etc/boilerplate/backup.env, preencha e `chmod 600`. NÃO commitar preenchido.
# Ver o passo-a-passo em infra/backup/README.md.

# Chave PÚBLICA age (recipient). A PRIVADA fica OFFSITE (fora da VPS-DATA) e só
# volta para o restore-drill. Gerar o par NA SUA máquina:
#   age-keygen -o backup-age.key    → "Public key: age1..." vai aqui.
AGE_RECIPIENT=age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remote rclone offsite (Cloudflare R2). Configurar antes:  rclone config
RCLONE_REMOTE=r2
RCLONE_BUCKET=boilerplate-backups

# Dead-man switch (healthchecks.io): crie um check diário e cole a ping URL.
# Se um backup falhar/não rodar, o healthchecks alerta.
HC_PING_URL=https://hc-ping.com/00000000-0000-0000-0000-000000000000

# Opcionais (defaults nos scripts):
# PG_CONTAINER=boilerplate-db
# PG_USER=boilerplate
# PG_DB=boilerplate
# Quantos dumps diários manter (count-based). A 2x/dia, 5 = ~2,5 dias de
# histórico rolante. O backup-db.sh apaga os mais antigos além deste número.
# DAILY_RETENTION_COUNT=5
# TMP_DIR=/tmp
