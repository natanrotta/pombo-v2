{
  "name": "@boilerplate/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical TypeScript contracts and shared runtime constants/helpers for @boilerplate/api and @boilerplate/web.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
